generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model BodyMetrics {
  id         Int      @id @default(autoincrement())
  date       DateTime
  weightKg   Float
  bodyFatPct Float?
  notes      String?

  @@map("body_metrics")
}

model Exercise {
  id                Int                @id @default(autoincrement())
  name              String
  muscleGroup       String
  repRangeLow       Int
  repRangeHigh      Int
  incrementKg       Float
  isPriority        Boolean            @default(false) @map("is_priority")
  templateExercises TemplateExercise[]
  workoutSets       WorkoutSet[]

  @@map("exercises")
}

model WorkoutTemplate {
  id                Int                @id @default(autoincrement())
  name              String
  isActive          Boolean            @default(true)
  templateExercises TemplateExercise[]
  workouts          Workout[]

  @@map("workout_templates")
}

model TemplateExercise {
  id         Int             @id @default(autoincrement())
  templateId Int
  exerciseId Int
  order      Int
  targetSets Int
  template   WorkoutTemplate @relation(fields: [templateId], references: [id])
  exercise   Exercise        @relation(fields: [exerciseId], references: [id])

  @@map("template_exercises")
}

model Mesocycle {
  id              Int       @id @default(autoincrement())
  startDate       DateTime
  lengthWeeks     Int
  currentWeek     Int       @default(1)
  blockNumber     Int       @default(1)  @map("block_number")
  workoutsPerWeek Int       @default(3)  @map("workouts_per_week")
  workouts        Workout[]

  @@map("mesocycles")
}

model Workout {
  id          Int             @id @default(autoincrement())
  date        DateTime
  templateId  Int
  mesocycleId Int?
  weekInBlock Int?
  notes       String?
  template    WorkoutTemplate @relation(fields: [templateId], references: [id])
  mesocycle   Mesocycle?      @relation(fields: [mesocycleId], references: [id])
  workoutSets WorkoutSet[]
  gymTrips    GymTrip[]

  @@map("workouts")
}

model WorkoutSet {
  id         Int      @id @default(autoincrement())
  workoutId  Int
  exerciseId Int
  setNumber  Int
  weightKg   Float
  reps       Int
  rir        Int
  workout    Workout  @relation(fields: [workoutId], references: [id])
  exercise   Exercise @relation(fields: [exerciseId], references: [id])

  @@map("workout_sets")
}

model Readiness {
  id         Int      @id @default(autoincrement())
  date       DateTime
  sleepHours Float    @map("sleep_hours")
  soreness   Int
  energy     Int
  notes      String?

  @@map("readiness")
}

model Meal {
  id                 Int              @id @default(autoincrement())
  name               String
  type               String
  kcal               Int
  proteinG           Float
  fatG               Float
  carbsG             Float
  isAirFryer         Boolean          @default(false)
  makesLeftovers     Boolean          @default(false)
  instructions       String?
  ingredients        MealIngredient[]
  mealPlanBreakfasts MealPlan[]       @relation("BreakfastMeal")
  mealPlanDinners    MealPlan[]       @relation("DinnerMeal")
  mealPlanSnacks     MealPlanSnack[]

  @@map("meals")
}

model MealIngredient {
  id               Int    @id @default(autoincrement())
  mealId           Int
  ingredientName   String
  quantity         Float
  unit             String
  supermarketAisle String
  meal             Meal   @relation(fields: [mealId], references: [id])

  @@map("meal_ingredients")
}

model MealPlan {
  id              Int             @id @default(autoincrement())
  date            DateTime
  breakfastMealId Int
  dinnerMealId    Int
  breakfastLocked Boolean         @default(false) @map("breakfast_locked")
  dinnerLocked    Boolean         @default(false) @map("dinner_locked")
  breakfastEaten   Boolean         @default(false) @map("breakfast_eaten")
  lunchEaten       Boolean         @default(true)  @map("lunch_eaten")
  dinnerEaten      Boolean         @default(false) @map("dinner_eaten")
  breakfastSkipped Boolean         @default(false) @map("breakfast_skipped")
  lunchSkipped     Boolean         @default(false) @map("lunch_skipped")
  dinnerSkipped    Boolean         @default(false) @map("dinner_skipped")
  breakfastMeal   Meal            @relation("BreakfastMeal", fields: [breakfastMealId], references: [id])
  dinnerMeal      Meal            @relation("DinnerMeal", fields: [dinnerMealId], references: [id])
  snacks          MealPlanSnack[]

  @@map("meal_plan")
}

model MealPlanSnack {
  id         Int      @id @default(autoincrement())
  mealPlanId Int      @map("meal_plan_id")
  mealId     Int      @map("meal_id")
  eaten      Boolean  @default(false)
  skipped    Boolean  @default(false)
  mealPlan   MealPlan @relation(fields: [mealPlanId], references: [id])
  meal       Meal     @relation(fields: [mealId], references: [id])

  @@map("meal_plan_snacks")
}

model OffPlanMeal {
  id          Int      @id @default(autoincrement())
  date        DateTime
  description String
  kcal        Int
  proteinG    Float    @map("protein_g")
  fatG        Float    @map("fat_g")
  carbsG      Float    @map("carbs_g")

  @@map("off_plan_meals")
}

model NutritionTarget {
  id        Int      @id @default(autoincrement())
  kcal      Int
  proteinG  Float    @map("protein_g")
  fatG      Float    @map("fat_g")
  carbsG    Float    @map("carbs_g")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("nutrition_targets")
}

model SupplementSetting {
  id             Int      @id @default(autoincrement())
  waterTargetMl  Int      @default(2000) @map("water_target_ml")
  waterServingMl Int      @default(500)  @map("water_serving_ml")
  creatineDoseG  Float    @default(5)    @map("creatine_dose_g")
  updatedAt      DateTime @updatedAt     @map("updated_at")

  @@map("supplement_settings")
}

model WaterIntake {
  id            Int      @id @default(autoincrement())
  date          DateTime
  completedMask Int      @default(0) @map("completed_mask")

  @@map("water_intake")
}

model CreatineLog {
  id    Int      @id @default(autoincrement())
  date  DateTime
  taken Boolean  @default(false)

  @@map("creatine_log")
}

model GymTrip {
  id                  Int      @id @default(autoincrement())
  date                DateTime
  workoutId           Int?     @map("workout_id")
  travelToMode        String   @map("travel_to_mode")
  travelToCalories    Int?     @map("travel_to_calories")
  travelToDistKm      Float?   @map("travel_to_dist_km")
  travelToDurMin      Float?   @map("travel_to_dur_min")
  travelFromMode      String   @map("travel_from_mode")
  travelFromCalories  Int?     @map("travel_from_calories")
  travelFromDistKm    Float?   @map("travel_from_dist_km")
  travelFromDurMin    Float?   @map("travel_from_dur_min")
  workoutCalories     Int?     @map("workout_calories")
  workout             Workout? @relation(fields: [workoutId], references: [id])

  @@map("gym_trips")
}
