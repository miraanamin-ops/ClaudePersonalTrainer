generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model BodyMetrics {
  id         Int      @id @default(autoincrement())
  date       DateTime
  weightKg   Float
  bodyFatPct Float?
  notes      String?

  @@map("body_metrics")
}

model Exercise {
  id                Int                @id @default(autoincrement())
  name              String
  muscleGroup       String
  repRangeLow       Int
  repRangeHigh      Int
  incrementKg       Float
  templateExercises TemplateExercise[]
  workoutSets       WorkoutSet[]

  @@map("exercises")
}

model WorkoutTemplate {
  id                Int                @id @default(autoincrement())
  name              String
  isActive          Boolean            @default(true)
  templateExercises TemplateExercise[]
  workouts          Workout[]

  @@map("workout_templates")
}

model TemplateExercise {
  id         Int             @id @default(autoincrement())
  templateId Int
  exerciseId Int
  order      Int
  targetSets Int
  template   WorkoutTemplate @relation(fields: [templateId], references: [id])
  exercise   Exercise        @relation(fields: [exerciseId], references: [id])

  @@map("template_exercises")
}

model Mesocycle {
  id          Int       @id @default(autoincrement())
  startDate   DateTime
  lengthWeeks Int
  currentWeek Int       @default(1)
  workouts    Workout[]

  @@map("mesocycles")
}

model Workout {
  id          Int             @id @default(autoincrement())
  date        DateTime
  templateId  Int
  mesocycleId Int?
  weekInBlock Int?
  notes       String?
  template    WorkoutTemplate @relation(fields: [templateId], references: [id])
  mesocycle   Mesocycle?      @relation(fields: [mesocycleId], references: [id])
  workoutSets WorkoutSet[]

  @@map("workouts")
}

model WorkoutSet {
  id         Int      @id @default(autoincrement())
  workoutId  Int
  exerciseId Int
  setNumber  Int
  weightKg   Float
  reps       Int
  rir        Int
  workout    Workout  @relation(fields: [workoutId], references: [id])
  exercise   Exercise @relation(fields: [exerciseId], references: [id])

  @@map("workout_sets")
}

model Readiness {
  id         Int      @id @default(autoincrement())
  date       DateTime
  sleepHours Float
  soreness   Int
  energy     Int
  notes      String?

  @@map("readiness")
}

model Meal {
  id                 Int              @id @default(autoincrement())
  name               String
  type               String
  kcal               Int
  proteinG           Float
  fatG               Float
  carbsG             Float
  isAirFryer         Boolean          @default(false)
  makesLeftovers     Boolean          @default(false)
  ingredients        MealIngredient[]
  mealPlanBreakfasts MealPlan[]       @relation("BreakfastMeal")
  mealPlanDinners    MealPlan[]       @relation("DinnerMeal")

  @@map("meals")
}

model MealIngredient {
  id               Int    @id @default(autoincrement())
  mealId           Int
  ingredientName   String
  quantity         Float
  unit             String
  supermarketAisle String
  meal             Meal   @relation(fields: [mealId], references: [id])

  @@map("meal_ingredients")
}

model MealPlan {
  id              Int      @id @default(autoincrement())
  date            DateTime
  breakfastMealId Int
  dinnerMealId    Int
  breakfastMeal   Meal     @relation("BreakfastMeal", fields: [breakfastMealId], references: [id])
  dinnerMeal      Meal     @relation("DinnerMeal", fields: [dinnerMealId], references: [id])

  @@map("meal_plan")
}
